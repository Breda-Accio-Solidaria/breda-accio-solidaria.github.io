---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Analytics from '../components/Analytics.astro';
import PreviewBanner from '../components/PreviewBanner.astro';
import '../styles/global.css';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title,
  description = site.description,
  image = '/images/og-default.jpg',
  noindex = false,
} = Astro.props;

const pageTitle = title ? `${title} | ${site.shortName}` : `${site.name} | ${site.tagline}`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
const socialImage = new URL(image, Astro.site ?? Astro.url);
---

<!doctype html>
<html lang="ca">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#3D3434" />
    <meta name="color-scheme" content="light" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/images/logo-bas-square.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="canonical" href={canonical} />
    <meta property="og:locale" content="ca_ES" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <title>{pageTitle}</title>
    <Analytics />
  </head>
  <body>
    <a class="skip-link" href="#contingut">Ves al contingut principal</a>
    <PreviewBanner />
    <Header />
    <main id="contingut"><slot /></main>
    <Footer />
  </body>
</html>
