---
import BaseLayout from './BaseLayout.astro';
import Badge from '../components/Badge.astro';

interface Props {
  title: string;
  summary: string;
  eyebrow: string;
  meta?: string;
  isPlaceholder?: boolean;
  topics?: string[];
  image?: string;
  imageAlt?: string;
}

const {
  title,
  summary,
  eyebrow,
  meta,
  isPlaceholder = false,
  topics = [],
  image,
  imageAlt = '',
} = Astro.props;
---

<BaseLayout title={title} description={summary} image={image}>
  <article>
    <header class="article-header">
      <div class="container narrow">
        <p class="eyebrow">{eyebrow}</p>
        <h1>{title}</h1>
        <p class="summary">{summary}</p>
        <div class="metadata">
          {meta && <span>{meta}</span>}
          {isPlaceholder && <Badge tone="purple">Exemple</Badge>}
        </div>
        {topics.length > 0 && (
          <ul class="topics" aria-label="Temes">
            {topics.map((topic) => <li>{topic}</li>)}
          </ul>
        )}
      </div>
    </header>

    {image && (
      <figure class="hero-image container">
        <img src={image} alt={imageAlt} />
      </figure>
    )}

    <div class="container narrow article-body prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .article-header {
    padding-block: clamp(3.5rem, 9vw, 7rem);
    background: var(--color-ink);
    color: var(--color-vanilla);
    border-top: 6px solid var(--color-red);
  }

  .narrow {
    max-width: 50rem;
  }

  .eyebrow {
    margin: 0 0 1rem;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 850;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-mint);
  }

  h1 {
    margin: 0;
    font-size: var(--text-h1);
    line-height: 0.98;
    text-wrap: balance;
  }

  .summary {
    margin: 1.4rem 0 0;
    font-size: var(--text-lead);
    color: #eee7db;
  }

  .metadata {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.8rem;
    margin-top: 1.3rem;
    font-size: 0.86rem;
    color: #d9d1c5;
  }

  .topics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 1.2rem 0 0;
  }

  .topics li {
    padding: 0.3rem 0.65rem;
    border: 1px solid rgb(255 255 255 / 0.35);
    font-size: 0.75rem;
  }

  .hero-image {
    margin-top: clamp(2rem, 5vw, 4rem);
    max-width: 66rem;
  }

  .hero-image img {
    width: 100%;
    max-height: 48rem;
    object-fit: contain;
    background: var(--color-cream);
    border: 1px solid var(--color-border);
  }

  .article-body {
    padding-block: clamp(3rem, 7vw, 6rem);
  }
</style>
