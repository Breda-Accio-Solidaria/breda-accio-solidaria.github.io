---
import type { CollectionEntry } from 'astro:content';
import Badge from './Badge.astro';
import { formatDateTime } from '../utils/format';
import { agendaFormatMeta } from '../data/agenda';

interface Props {
  item: CollectionEntry<'agenda'>;
}
const { item } = Astro.props;
const formatMeta = agendaFormatMeta[item.data.format];
const dateParts = new Intl.DateTimeFormat('ca-ES', { day: '2-digit', month: 'short' }).formatToParts(item.data.startDate);
const day = dateParts.find((p) => p.type === 'day')?.value;
const month = dateParts.find((p) => p.type === 'month')?.value?.replace('.', '');
---

<article class="event-card">
  <div class="date" aria-hidden="true">
    <strong>{day}</strong>
    <span>{month}</span>
  </div>
  <div class="body">
    <div class="meta">
    <Badge
      tone={
        item.data.status === 'cancel·lada'
          ? 'red'
          : item.data.status === 'finalitzada'
            ? 'neutral'
            : 'mint'
      }
    >
      {item.data.status}
    </Badge>

    <Badge tone={formatMeta.tone}>
      {formatMeta.label}
    </Badge>
  </div>
    <h3><a href={`/agenda/${item.id}/`}>{item.data.title}</a></h3>
    <p>{item.data.summary}</p>
    <dl>
      <div>
        <dt>Quan</dt>
        <dd>{formatDateTime(item.data.startDate)}</dd>
      </div>
      <div>
        <dt>On</dt>
        <dd>{item.data.location}</dd>
      </div>
    </dl>
  </div>
</article>

<style>
  .event-card {
    display: grid;
    grid-template-columns: 6rem 1fr;
    min-height: 100%;
    background: white;
    border: 1px solid var(--color-border-strong);
  }

  .date {
    display: grid;
    align-content: start;
    justify-items: center;
    gap: 0.2rem;
    padding: 1.3rem 0.7rem;
    background: var(--color-ink);
    color: var(--color-vanilla);
    border-top: 5px solid var(--color-green);
  }

  .date strong {
    font-family: var(--font-serif);
    font-size: 2.6rem;
    line-height: 1;
  }

  .date span {
    font-weight: 850;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .body {
    padding: 1.3rem;
  }

  .meta {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  h3 {
    margin: 0.85rem 0 0;
    font-size: 1.45rem;
    line-height: 1.12;
  }

  h3 a {
    color: var(--color-ink);
    text-decoration-color: transparent;
  }

  h3 a:hover {
    text-decoration-color: var(--color-red);
  }

  p {
    color: var(--color-muted);
  }

  dl {
    display: grid;
    gap: 0.55rem;
    margin: 1rem 0 0;
    font-size: 0.88rem;
  }

  dl div {
    display: grid;
    grid-template-columns: 3.4rem 1fr;
    gap: 0.5rem;
  }

  dt {
    font-weight: 800;
  }

  dd {
    margin: 0;
    color: var(--color-muted);
  }

  @media (max-width: 32rem) {
    .event-card {
      grid-template-columns: 4.7rem 1fr;
    }

    .date strong {
      font-size: 2.1rem;
    }
  }
</style>
