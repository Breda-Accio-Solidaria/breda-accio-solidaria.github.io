---
import Logo from './Logo.astro';
import { site } from '../data/site';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="green-line" aria-hidden="true"></div>
  <div class="container footer-grid">
    <div>
      <Logo inverse />
      <p class="intro">
        Associació sense ànim de lucre de Breda dedicada a la sensibilització, la solidaritat,
        els drets humans i la defensa del medi ambient.
      </p>
      <p><a href={`mailto:${site.email}`}>{site.email}</a></p>
    </div>

    <div>
      <h2>Explora</h2>
      <ul>
        <li><a href="/associacio/">L'associació</a></li>
        <li><a href="/campanyes/">Acció</a></li>
        <li><a href="/actualitat/">Continguts</a></li>
        <li><a href="/agenda/">Agenda</a></li>
        <li><a href="/participa/">Participa</a></li>
      </ul>
    </div>

    <div>
      <h2>Informació</h2>
      <ul>
        <li><a href="/transparencia/">Transparència</a></li>
        <li><a href="/contacte/">Contacte</a></li>
        <li><a href="/avis-legal/">Avís legal</a></li>
        <li><a href="/privacitat/">Privacitat</a></li>
        <li><a href="/accessibilitat/">Accessibilitat</a></li>
      </ul>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>© {year} {site.name}.</p>
    <p>Web estàtica, accessible i sense galetes publicitàries.</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-section);
    background: var(--color-ink);
    color: var(--color-vanilla);
  }

  .green-line {
    height: 6px;
    background: var(--color-green);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: minmax(0, 2fr) repeat(2, minmax(10rem, 1fr));
    gap: clamp(2rem, 6vw, 6rem);
    padding-block: clamp(3rem, 7vw, 5rem);
  }

  .intro {
    max-width: 42rem;
    color: #eee7db;
    margin-top: 1.4rem;
  }

  h2 {
    margin: 0 0 1rem;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.13em;
    color: var(--color-mint);
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.55rem;
  }

  a {
    color: var(--color-vanilla);
    text-underline-offset: 0.2em;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    padding-block: 1.2rem;
    border-top: 1px solid rgb(255 255 255 / 0.2);
    font-size: 0.82rem;
    color: #d9d1c5;
  }

  .footer-bottom p {
    margin: 0;
  }

  @media (max-width: 48rem) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      display: grid;
      gap: 0.45rem;
    }
  }
</style>
