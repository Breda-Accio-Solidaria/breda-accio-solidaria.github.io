---
import type { CollectionEntry } from 'astro:content';
import Badge from './Badge.astro';
import { formatDate, humanize } from '../utils/format';

interface Props {
  item: CollectionEntry<'actualitat'>;
}
const { item } = Astro.props;
---

<article class="card">
  {item.data.image ? (
    <a class="visual" href={`/actualitat/${item.id}/`} tabindex="-1" aria-hidden="true">
      <img src={item.data.image} alt="" loading="lazy" />
    </a>
  ) : (
    <div class="visual fallback" aria-hidden="true"><span>{item.data.type}</span></div>
  )}
  <div class="body">
    <div class="meta">
      <Badge tone="mint">{humanize(item.data.type)}</Badge>
      {item.data.isPlaceholder && <Badge tone="purple">Exemple</Badge>}
    </div>
    <h3><a href={`/actualitat/${item.id}/`}>{item.data.title}</a></h3>
    <p>{item.data.summary}</p>
    <time datetime={item.data.publishedAt.toISOString()}>{formatDate(item.data.publishedAt)}</time>
  </div>
</article>

<style>
  .card {
    display: grid;
    grid-template-rows: auto 1fr;
    min-height: 100%;
    background: white;
    border: 1px solid var(--color-border-strong);
    transition: transform 160ms ease, box-shadow 160ms ease;
  }

  .card:hover {
    transform: translateY(-3px);
    box-shadow: 0 0.8rem 2rem rgb(61 52 52 / 0.12);
  }

  .visual {
    display: block;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--color-ink);
  }

  .visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 250ms ease;
  }

  .card:hover .visual img {
    transform: scale(1.025);
  }

  .fallback {
    display: flex;
    align-items: flex-end;
    padding: 1rem;
    color: white;
    background:
      linear-gradient(135deg, transparent 0 50%, rgb(227 6 19 / 0.9) 50% 64%, transparent 64%),
      linear-gradient(35deg, var(--color-ink), #1d1a1a);
  }

  .fallback span {
    font-size: 0.72rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .body {
    display: flex;
    flex-direction: column;
    padding: 1.35rem;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  h3 {
    margin: 1rem 0 0;
    font-size: 1.45rem;
    line-height: 1.12;
  }

  h3 a {
    color: var(--color-ink);
    text-decoration-color: transparent;
  }

  h3 a:hover {
    text-decoration-color: var(--color-red);
  }

  p {
    color: var(--color-muted);
  }

  time {
    margin-top: auto;
    padding-top: 1rem;
    font-size: 0.82rem;
    font-weight: 750;
    color: var(--color-muted);
  }
</style>
