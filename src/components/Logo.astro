---
import { site } from '../data/site';

interface Props {
  compact?: boolean;
  inverse?: boolean;
}

const { compact = false, inverse = false } = Astro.props;
---

<a class:list={['brand', { compact, inverse }]} href="/" aria-label={`${site.name}, inici`}>
  <img src="/images/logo-bas.png" width="720" height="720" alt="" />
  {!compact && (
    <span class="brand-copy">
      <strong>{site.name}</strong>
      <small>{site.tagline}</small>
    </span>
  )}
</a>

<style>
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
    color: var(--color-ink);
    text-decoration: none;
  }

  img {
    width: 3.6rem;
    height: 3.6rem;
    object-fit: contain;
    flex: 0 0 auto;
  }

  .brand-copy {
    display: grid;
    min-width: 0;
  }

  strong {
    font-family: var(--font-serif);
    font-size: clamp(1rem, 1.7vw, 1.24rem);
    line-height: 1.05;
    white-space: nowrap;
  }

  small {
    margin-top: 0.2rem;
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    color: var(--color-muted);
    white-space: nowrap;
  }

  .inverse {
    color: var(--color-vanilla);
  }

  .inverse small {
    color: var(--color-mint);
  }

  .inverse img {
    border-radius: 50%;
    background: white;
  }

  .compact img {
    width: 3rem;
    height: 3rem;
  }

  @media (max-width: 38rem) {
    img {
      width: 3.1rem;
      height: 3.1rem;
    }

    .brand-copy small {
      display: none;
    }

    strong {
      font-size: 0.94rem;
      white-space: normal;
    }
  }
</style>
