---
import Logo from './Logo.astro';
import { mainNavigation } from '../data/site';

const pathname = Astro.url.pathname;
const isActive = (href: string) => href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<header class="site-header">
  <div class="top-line" aria-hidden="true"></div>
  <div class="container header-inner">
    <Logo />

    <nav class="desktop-nav" aria-label="Navegació principal">
      <ul>
        {mainNavigation.map((item) => (
          <li>
            <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
      <a class="contact-link" href="/contacte/">Contacte</a>
    </nav>

    <details class="mobile-nav">
      <summary aria-label="Obre el menú de navegació">
        <span>Menú</span>
        <span class="menu-icon" aria-hidden="true"></span>
      </summary>
      <nav aria-label="Navegació mòbil">
        <ul>
          {mainNavigation.map((item) => (
            <li>
              <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
                {item.label}
              </a>
            </li>
          ))}
          <li><a href="/transparencia/">Transparència</a></li>
          <li><a href="/contacte/">Contacte</a></li>
        </ul>
      </nav>
    </details>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: color-mix(in srgb, var(--color-vanilla) 95%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .top-line {
    height: 4px;
    background: var(--color-red);
  }

  .header-inner {
    min-height: 5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
  }

  .desktop-nav {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  ul {
    display: flex;
    align-items: center;
    gap: 0.05rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  a {
    display: inline-flex;
    align-items: center;
    min-height: 2.75rem;
    padding: 0.5rem 0.58rem;
    color: var(--color-ink);
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: 700;
    border-bottom: 3px solid transparent;
  }

  a:hover,
  a[aria-current='page'] {
    border-bottom-color: var(--color-red);
  }

  .contact-link {
    padding-inline: 0.95rem;
    background: var(--color-ink);
    color: var(--color-vanilla);
    border: 2px solid var(--color-ink);
  }

  .contact-link:hover {
    background: transparent;
    color: var(--color-ink);
  }

  .mobile-nav {
    display: none;
    position: relative;
  }

  summary {
    cursor: pointer;
    list-style: none;
    min-height: 2.9rem;
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.55rem 0.9rem;
    background: var(--color-ink);
    color: var(--color-vanilla);
    font-weight: 800;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  .menu-icon,
  .menu-icon::before,
  .menu-icon::after {
    width: 1.15rem;
    height: 2px;
    background: currentColor;
  }

  .menu-icon {
    position: relative;
  }

  .menu-icon::before,
  .menu-icon::after {
    content: '';
    position: absolute;
    left: 0;
  }

  .menu-icon::before { top: -0.38rem; }
  .menu-icon::after { top: 0.38rem; }

  .mobile-nav nav {
    position: absolute;
    right: 0;
    top: calc(100% + 0.5rem);
    width: min(20rem, calc(100vw - 1.5rem));
    max-height: calc(100vh - 7rem);
    overflow-y: auto;
    padding: 0.7rem;
    background: var(--color-vanilla);
    border: 2px solid var(--color-ink);
    box-shadow: var(--shadow-lg);
  }

  .mobile-nav ul {
    display: grid;
  }

  .mobile-nav a {
    width: 100%;
    justify-content: flex-start;
    font-size: 1rem;
    padding-inline: 0.8rem;
  }

  @media (max-width: 74rem) {
    .desktop-nav {
      display: none;
    }

    .mobile-nav {
      display: block;
    }
  }
</style>
