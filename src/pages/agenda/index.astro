---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import EventCard from '../../components/EventCard.astro';

const items = await getCollection('agenda', ({ data }) => !data.draft);
const upcoming = items
  .filter((item) => item.data.status === 'programada')
  .sort((a, b) => a.data.startDate.valueOf() - b.data.startDate.valueOf());
const past = items
  .filter((item) => item.data.status === 'finalitzada')
  .sort((a, b) => b.data.startDate.valueOf() - a.data.startDate.valueOf());
---

<BaseLayout title="Agenda">
  <PageHeader
    eyebrow="Agenda"
    title="Ens trobem, parlem i actuem"
    intro="Consulta les properes xerrades, cinefòrums, cercles d'estudi i activitats solidàries de BAS."
    dark
  />

  <section class="section upcoming">
    <div class="container">
      <SectionHeading eyebrow="Properament" title="Activitats programades" />
      <div class="grid-3">
        {upcoming.map((item) => <EventCard item={item} />)}
      </div>
    </div>
  </section>

  <section class="section past">
    <div class="container">
      <SectionHeading eyebrow="Arxiu" title="Activitats realitzades" />
      <div class="grid-2">
        {past.map((item) => <EventCard item={item} />)}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .upcoming {
    background: var(--color-mint);
  }

  .past {
    border-top: 1px solid var(--color-border);
  }
</style>
