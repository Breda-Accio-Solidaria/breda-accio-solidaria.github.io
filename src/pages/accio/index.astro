---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import ButtonLink from '../../components/ButtonLink.astro';
---

<BaseLayout title="Acció">
  <PageHeader
    eyebrow="Acció"
    title="De la reflexió a la pràctica"
    intro="BAS combina sensibilització, formació, solidaritat i mobilització. Cada àmbit es treballa amb activitats públiques, campanyes i aliances."
    dark
  />

  <section class="section">
    <div class="container actions-grid">
      <article class="palestine">
        <p class="number">01</p>
        <h2>Palestina i drets humans</h2>
        <p>
          Organitzem xerrades, materials de sensibilització i iniciatives de boicot i solidaritat.
          Volem trencar el silenci, defensar el dret internacional i connectar Breda amb xarxes
          de mobilització més àmplies.
        </p>
        <a href="/campanyes/palestina-solidaritat-i-boicot/">Veure la campanya →</a>
      </article>

      <article>
        <p class="number">02</p>
        <h2>Antiracisme i extrema dreta</h2>
        <p>
          Impulsem espais per entendre per què arrelen els discursos autoritaris, racistes i
          excloents, i per construir respostes democràtiques, socials i comunitàries.
        </p>
        <a href="/campanyes/contra-extrema-dreta/">Veure la campanya →</a>
      </article>

      <article>
        <p class="number">03</p>
        <h2>Solidaritat internacional</h2>
        <p>
          Donem suport a pobles, col·lectius i projectes que defensen la dignitat, la sobirania
          i la justícia social. La solidaritat amb Cuba forma part de les finalitats de BAS.
        </p>
        <a href="/campanyes/solidaritat-amb-cuba/">Solidaritat amb Cuba →</a>
      </article>

      <article class="environment">
        <p class="number">04</p>
        <h2>Medi ambient i territori</h2>
        <p>
          Treballem la relació entre ecologia, economia i democràcia: biodiversitat, paisatge,
          residus, agricultura, sobirania alimentària i efectes locals de la crisi climàtica.
        </p>
        <a href="/campanyes/medi-ambient-i-territori/">Veure la campanya →</a>
      </article>

      <article>
        <p class="number">05</p>
        <h2>Cercles d'estudi</h2>
        <p>
          Llegim, compartim experiències i debatim sense pressa. Els cercles d'estudi ajuden a
          construir criteri propi i a preparar noves línies d'acció.
        </p>
        <a href="/actualitat/cercle-estudi-persones-bones-coses-dolentes/">Llegir la crònica →</a>
      </article>

      <article>
        <p class="number">06</p>
        <h2>Cooperació local</h2>
        <p>
          Col·laborem amb entitats de Breda i de l'entorn per ampliar l'abast de les activitats,
          compartir recursos i reforçar el teixit associatiu.
        </p>
        <a href="/contacte/">Proposa una col·laboració →</a>
      </article>
    </div>
  </section>

  <section class="section formats">
    <div class="container split">
      <SectionHeading eyebrow="Formats" title="Com treballem" />
      <div class="grid-2">
        <div><strong>Xerrades i debats</strong><p>Testimonis directes, anàlisi experta i participació del públic.</p></div>
        <div><strong>Cinefòrums</strong><p>Documentals i pel·lícules com a punt de partida per al debat col·lectiu.</p></div>
        <div><strong>Campanyes</strong><p>Materials, xarxes, accions de carrer i coordinació amb altres moviments.</p></div>
        <div><strong>Activitats solidàries</strong><p>Recollida de fons, suport material i visibilització de projectes.</p></div>
      </div>
    </div>
  </section>

  <section class="section cta">
    <div class="container cta-inner">
      <div>
        <h2>Tens una proposta per a Breda?</h2>
        <p>Explica'ns el tema, el format i les persones o entitats amb qui voldries treballar.</p>
      </div>
      <ButtonLink href="/contacte/" variant="light">Contacta amb BAS</ButtonLink>
    </div>
  </section>
</BaseLayout>

<style>
  .actions-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }

  article {
    min-height: 22rem;
    padding: clamp(1.5rem, 4vw, 3rem);
    background: white;
    border: 1px solid var(--color-border-strong);
  }

  article.palestine {
    background: var(--color-ink);
    color: var(--color-vanilla);
  }

  article.environment {
    background: var(--color-green-dark);
    color: white;
  }

  article h2 {
    margin: 0.5rem 0 1rem;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
  }

  article p {
    max-width: 45rem;
  }

  article a {
    display: inline-flex;
    margin-top: 1rem;
    color: inherit;
    font-weight: 850;
  }

  .number {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 2.8rem;
    color: var(--color-red);
  }

  .environment .number {
    color: var(--color-lemon);
  }

  .formats {
    background: var(--color-cream);
  }

  .split {
    display: grid;
    grid-template-columns: minmax(0, 0.7fr) minmax(0, 1.3fr);
    gap: clamp(2.5rem, 8vw, 8rem);
  }

  .formats .grid-2 > div {
    padding: 1.25rem;
    background: var(--color-vanilla);
    border-left: 5px solid var(--color-green);
  }

  .formats strong {
    font-family: var(--font-serif);
    font-size: 1.35rem;
  }

  .cta {
    background: var(--color-red);
    color: white;
  }

  .cta-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 3rem;
  }

  .cta h2 {
    margin: 0;
    font-size: var(--text-h2);
  }

  @media (max-width: 48rem) {
    .actions-grid,
    .split {
      grid-template-columns: 1fr;
    }

    .cta-inner {
      display: grid;
    }
  }
</style>
